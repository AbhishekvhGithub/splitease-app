# Frontend Environment Variables
# This file shows how to configure the frontend API endpoint

# For development (local):
# REACT_APP_API_URL=http://localhost:3001/api

# For production (Vercel):
# REACT_APP_API_URL=https://splitease-app-rkgp.onrender.com/api

# Backend Environment Variables (Render only)
# These are configured in Render dashboard

# Node environment
NODE_ENV=production

# Frontend path (for Render serving static files)
FRONTEND_PATH=/opt/render/project/frontend/public

# CORS settings (add your Vercel domain here)
# CORS_ORIGINS=https://splitease-app.vercel.app

# Optional: API rate limiting
# API_RATE_LIMIT=100
