{
  "buildCommand": "echo 'Frontend build complete'",
  "installCommand": "echo 'No dependencies to install'",
  "framework": "static",
  "public": "frontend/public",
  "env": {
    "REACT_APP_API_URL": "@api_url"
  },
  "routes": [
    {
      "src": "^/(?!api).*",
      "dest": "frontend/public/index.html"
    }
  ]
}
